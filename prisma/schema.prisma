generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

// ─── Brand ──────────────────────────────────────────────────────────────────

model Brand {
  id                   String         @id @default(cuid())
  name                 String         @unique
  tagline              String?
  identityMarkdown     String?        @db.Text // Full brand identity doc (ingested MD)
  language             String
  tone                 String
  editorialCovers      String         // JSON array of topics
  editorialNever       String         // JSON array of exclusions
  audienceSize         String?
  audienceDemographics String?        // JSON object
  audienceGeography    String?        // JSON object
  audienceInterests    String?        // JSON object
  audienceDescription  String?
  activePlatforms      String         // JSON array of { name, role }
  voiceRules           Json           // Voice rules as native JSON
  editorialPriorities  String         // JSON array
  contentFrequency     String?        // JSON object
  isActive             Boolean        @default(true)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  contentPieces        ContentPiece[]
  narratives           Narrative[]

  @@index([isActive])
}

// ─── Narrative Trees (Semantic Memory) ──────────────────────────────────────

model NarrativeTree {
  id         String                      @id @default(cuid())
  rootTrend  String                      // Primary signal title
  summary    String?         @db.Text    // AI-generated tree summary
  embedding  String?       @db.Text    // Serialized embedding vector (JSON array of floats)
  status     NarrativeTreeStatus         @default(ACTIVE)
  nodes      NarrativeNode[]
  dossier    FactDossier?
  createdAt  DateTime                    @default(now())
  updatedAt  DateTime                    @updatedAt
}

enum NarrativeTreeStatus {
  ACTIVE
  MERGED
  ARCHIVED
}

model NarrativeNode {
  id           String        @id @default(cuid())
  treeId       String
  tree         NarrativeTree @relation(fields: [treeId], references: [id], onDelete: Cascade)
  signalData   Json          // Raw Khabri payload
  signalTitle  String        // Quick-access headline
  signalScore  Int           @default(0)
  identifiedAt DateTime      @default(now())

  @@index([treeId])
}

model FactDossier {
  id             String        @id @default(cuid())
  treeId         String        @unique
  tree           NarrativeTree @relation(fields: [treeId], references: [id], onDelete: Cascade)
  structuredData Json          // { facts, stats, quotes, timeline }
  sources        String[]      // Array of source URLs
  rawResearch    String?       @db.Text // Full research text before synthesis
  lastUpdated    DateTime      @updatedAt
  createdAt      DateTime      @default(now())
}

// ─── Content Pieces (Multi-Platform Deliverables) ───────────────────────────

model ContentPiece {
  id            String        @id @default(cuid())
  brandId       String
  brand         Brand         @relation(fields: [brandId], references: [id])
  treeId        String?       // Optional link to NarrativeTree
  platform      Platform
  status        ContentStatus @default(PLANNED)
  bodyText      String        @db.Text
  postingPlan   Json?         // Timing, hashtags, engagement strategy
  visualPrompts String?       @db.Text // Nano Banana structural prompts
  performanceData Json?       // Fed back from Relay
  approvedAt    DateTime?
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([brandId])
  @@index([status])
  @@index([platform])
}

enum Platform {
  YOUTUBE
  X_THREAD
  X_SINGLE
  BLOG
  LINKEDIN
  META_REEL
  META_CAROUSEL
  META_POST
}

enum ContentStatus {
  PLANNED
  RESEARCHING
  DRAFTED
  APPROVED
  RELAYED
  PUBLISHED
  KILLED
}

// ─── Legacy Models (kept for migration compatibility) ───────────────────────

model PlatformRule {
  id                String   @id @default(cuid())
  narrativeType     String
  primaryPlatform   String
  secondaryPlatform String?
  brandName         String?
  sendWhen          String   // JSON array
  neverSend         String   // JSON array
  speedPriority     String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TrendBatch {
  id         String   @id @default(cuid())
  importedAt DateTime @default(now())
  source     String   @default("khabri_manual")
  trends     Trend[]
}

model Trend {
  id         String      @id @default(cuid())
  rank       Int
  score      Int
  headline   String
  reason     String
  status     String      @default("pending")
  skipReason String?
  batchId    String
  batch      TrendBatch  @relation(fields: [batchId], references: [id])
  createdAt  DateTime    @default(now())
  narratives Narrative[]

  @@index([batchId])
  @@index([status])
}

model Narrative {
  id                String   @id @default(cuid())
  angle             String
  whyThisAngle      String
  informationGap    String
  priority          Int
  platform          String
  secondaryPlatform String?
  format            String
  urgency           String
  status            String   @default("planned")
  trendId           String
  trend             Trend    @relation(fields: [trendId], references: [id])
  brandId           String
  brand             Brand    @relation(fields: [brandId], references: [id])
  researchPrompt    String?
  researchResults   String?  @db.Text
  enginePrompt      String?  @db.Text
  packageData       String?  @db.Text
  finalContent      String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([trendId])
  @@index([brandId])
  @@index([status])
}

model EditorialLog {
  id             String   @id @default(cuid())
  action         String
  reasoning      String
  trendHeadline  String
  narrativeAngle String?
  platform       String?
  brandName      String?
  createdAt      DateTime @default(now())

  @@index([action])
}

model PerformanceData {
  id             String    @id @default(cuid())
  narrativeId    String?
  platform       String
  brandName      String
  contentType    String
  impressions    Int?
  engagementRate Float?
  replies        Int?
  retweets       Int?
  bookmarks      Int?
  views          Int?
  watchTime      Float?
  ctr            Float?
  notes          String?
  publishedAt    DateTime?
  recordedAt     DateTime  @default(now())

  @@index([platform])
  @@index([brandName])
}
